# Python bytecode caches
__pycache__/
*.pyc
*.pyo
*.pyd

# Test / coverage caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.benchmarks/
.ruff_cache/

# PyInstaller build artefacts
build/
dist/
*.spec

# Local logs
logs/
*.log

# User-managed project content
projects/

# Runtime-created config (user_action_map is owned by ConfigManager and
# regenerated per-user; only the shipped defaults should be versioned).
configs/user_action_map.json

# Operating system metadata
.DS_Store
Thumbs.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# Local virtual environments
.venv/
venv/
env/

# Local environment overrides
.env

# Claude Code local session/settings (developer tooling only)
.claude/

# Test suite is maintained locally only; not shipped with the public repo
tests/

# Internal developer tooling (env checks, PE inspector, leak checker)
tools/
scripts/_phase8_leak_check.py

# Release notes are managed via the GitHub Releases page rather than a
# checked-in changelog file
CHANGELOG.md

# Temporary directory used when downloading release artifacts via gh CLI
_release_artifacts_tmp/

# MkDocs build output (site/ is generated by `mkdocs build`)
/site/
